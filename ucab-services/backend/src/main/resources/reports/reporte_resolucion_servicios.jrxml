            </textField>
            <staticText>
                <reportElement x="240" y="32" width="130" height="14"
                               uuid="5e6f7a8b-0005-4000-e005-000000000005"/>
                <textElement><font fontName="Arial" size="9" isBold="true"/></textElement>
                <text><![CDATA[Solicitudes Completadas:]]></text>
            </staticText>
            <textField>
                <reportElement x="375" y="32" width="80" height="14" forecolor="#006E2F"
                               uuid="5e6f7a8b-0005-4000-e005-000000000006"/>
                <textElement><font fontName="Arial" size="9" isBold="true"/></textElement>
                <textFieldExpression><![CDATA[$V{totalCompletadasGlobal}]]></textFieldExpression>
            </textField>
            <staticText>
                <reportElement x="480" y="32" width="160" height="14"
                               uuid="5e6f7a8b-0005-4000-e005-000000000007"/>
                <textElement><font fontName="Arial" size="9" isBold="true"/></textElement>
                <text><![CDATA[% Completadas del total:]]></text>
            </staticText>
            <textField>
                <reportElement x="645" y="32" width="137" height="14" forecolor="#006E2F"
                               uuid="5e6f7a8b-0005-4000-e005-000000000008"/>
                <textElement><font fontName="Arial" size="9" isBold="true"/></textElement>
                <textFieldExpression><![CDATA[$V{totalGlobal} != null && $V{totalGlobal} > 0 ? String.format("%.1f %%", 100.0 * $V{totalCompletadasGlobal} / $V{totalGlobal}) : "N/A"]]></textFieldExpression>
            </textField>
            <staticText>
                <reportElement x="0" y="60" width="782" height="36" forecolor="#565E74"
                               uuid="5e6f7a8b-0005-4000-e005-000000000009"/>
                <textElement><font fontName="Arial" size="7" isItalic="true"/></textElement>
                <text><![CDATA[Nota: SLA de referencia = 5 días calendario. Solicitudes Pendientes/En Proceso no se incluyen en el tiempo promedio.
Tiempo_resolucion = diferencia entre Fecha_Fin y Fecha_Inicio de cada solicitud completada.
SLA% = (Completadas en <= 5 días / Total completadas) x 100.]]></text>
            </staticText>
        </band>
    </summary>

</jasperReport>
