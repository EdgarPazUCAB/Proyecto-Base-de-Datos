<?xml version="1.0" encoding="UTF-8"?>
<jasperReport
        xmlns="http://jasperreports.sourceforge.net/jasperreports"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
            http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
        name="reporte_resolucion_servicios"
        pageWidth="842"
        pageHeight="595"
        orientation="Landscape"
        columnWidth="782"
        leftMargin="30"
        rightMargin="30"
        topMargin="30"
        bottomMargin="30"
        uuid="b2c3d4e5-f6a7-4901-bcde-f12345678901">

    <parameter name="fechaInicio" class="java.lang.String">
        <defaultValueExpression><![CDATA["2000-01-01"]]></defaultValueExpression>
    </parameter>
    <parameter name="fechaFin" class="java.lang.String">
        <defaultValueExpression><![CDATA["2099-12-31"]]></defaultValueExpression>
    </parameter>

    <queryString language="SQL">
        <![CDATA[
            SELECT
                s.Codigo_Servicio                                        AS "codigoServicio",
                s.Descripcion_detallada                                  AS "descripcionServicio",
                CASE ep.tipo_entidad
                    WHEN 'Interna' THEN COALESCE(i.director_oficina, 'Entidad Interna #' || ep.id_entidad::text)
                    WHEN 'Externa' THEN COALESCE(e.razon_social,     'Entidad Externa #' || ep.id_entidad::text)
                    ELSE 'Desconocida'
                END                                                      AS "dependencia",
                COUNT(ss.Identificador)                                  AS "totalSolicitudes",
                COUNT(CASE WHEN ss.Estado_actual = 'Completada' THEN 1 END) AS "completadas",
                COUNT(CASE WHEN ss.Estado_actual = 'Pendiente'  THEN 1 END) AS "pendientes",
                COUNT(CASE WHEN ss.Estado_actual = 'En_Proceso' THEN 1 END) AS "enProceso",
                COUNT(CASE WHEN ss.Estado_actual = 'Cancelada'  THEN 1 END) AS "canceladas",
                ROUND(
                    AVG(EXTRACT(EPOCH FROM ss.Tiempo_resolucion) / 86400.0)
                    FILTER (WHERE ss.Tiempo_resolucion IS NOT NULL AND ss.Estado_actual = 'Completada'),
                    1
                )                                                        AS "tiempoPromediosDias",
                ROUND(
                    100.0 * COUNT(
                        CASE
                            WHEN ss.Estado_actual = 'Completada'
                             AND ss.Tiempo_resolucion IS NOT NULL
                             AND EXTRACT(EPOCH FROM ss.Tiempo_resolucion)/86400.0 <= 5
                            THEN 1
                        END
                    ) / NULLIF(COUNT(CASE WHEN ss.Estado_actual = 'Completada' THEN 1 END), 0),
                    1
                )                                                        AS "porcentajeATiempo"
            FROM Solicitud_Servicio ss
            JOIN Servicio s            ON ss.Codigo_Servicio = s.Codigo_Servicio
            JOIN Entidad_Prestadora ep ON s.id_entidad = ep.id_entidad
            LEFT JOIN Interna i        ON ep.id_entidad = i.id_entidad
            LEFT JOIN Externa e        ON ep.id_entidad = e.id_entidad
            WHERE ss.Fecha_creacion::date BETWEEN $P{fechaInicio}::date AND $P{fechaFin}::date
            GROUP BY
                s.Codigo_Servicio,
                s.Descripcion_detallada,
                ep.tipo_entidad,
                ep.id_entidad,
                i.director_oficina,
                e.razon_social
            ORDER BY COUNT(ss.Identificador) DESC
        ]]>
    </queryString>

    <field name="codigoServicio"      class="java.lang.String"/>
    <field name="descripcionServicio" class="java.lang.String"/>
    <field name="dependencia"         class="java.lang.String"/>
    <field name="totalSolicitudes"    class="java.lang.Long"/>
    <field name="completadas"         class="java.lang.Long"/>
    <field name="pendientes"          class="java.lang.Long"/>
    <field name="enProceso"           class="java.lang.Long"/>
    <field name="canceladas"          class="java.lang.Long"/>
    <field name="tiempoPromediosDias" class="java.math.BigDecimal"/>
    <field name="porcentajeATiempo"   class="java.math.BigDecimal"/>

    <variable name="totalGlobal" class="java.lang.Long" calculation="Sum">
        <variableExpression><![CDATA[$F{totalSolicitudes}]]></variableExpression>
    </variable>
    <variable name="totalCompletadasGlobal" class="java.lang.Long" calculation="Sum">
        <variableExpression><![CDATA[$F{completadas}]]></variableExpression>
    </variable>
    <variable name="rowNum" class="java.lang.Integer" calculation="Count">
        <variableExpression><![CDATA[true]]></variableExpression>
    </variable>

